   882	            &FakeHasher::ok([5; 32]),
   883	            store,
   884	            policy(),
   885	        ));
   886	        assert!(report.is_ok());
   887	        // The gate passed, so the bounded sync ran exactly once.
   888	        assert_eq!(sync_writes.load(Ordering::SeqCst), 1);
   889	    }
