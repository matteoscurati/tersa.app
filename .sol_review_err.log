   856	    fn a_blocked_gate_never_reaches_the_sync_write() {
   857	        let store = FakeStore::with_stored([5; 32]);
   858	        let sync_writes = store.sync_probe();
   859	        let error = drive(gated_sync(
   860	            &account(),
   861	            FakeProfile(subject("user-sub")),
   862	            &FakeHasher::failing(),
   863	            store,
   864	            policy(),
   865	        ))
   866	        .unwrap_err();
   867	        assert!(matches!(
   868	            error,
   869	            GatedSyncError::Gate(GateError::Hasher(HasherError::Unavailable))
   870	        ));
   871	        // The gate blocked before the coordinator existed: no sync write ran.
   872	        assert_eq!(sync_writes.load(Ordering::SeqCst), 0);
   873	    }
