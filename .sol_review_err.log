   666	        fn get_message(&self, id: &MessageId) -> Result<Option<Message>, MailboxStoreError> {
   667	            self.with_connection(|connection| {
   668	                let max_content_len = i64::try_from(MessageContent::MAX_LEN)
   669	                    .map_err(|_error| MailboxStoreError::Corrupted)?;
   670	                let mut statement = connection.prepare("SELECT CASE WHEN typeof(message_id) = 'text' AND length(CAST(message_id AS BLOB)) <= 256 THEN message_id END, CASE WHEN typeof(thread_id) = 'text' AND length(CAST(thread_id AS BLOB)) <= 256 THEN thread_id END, CASE WHEN typeof(sender) = 'text' AND length(CAST(sender AS BLOB)) <= 1024 THEN sender END, CASE WHEN typeof(subject) = 'text' AND length(CAST(subject AS BLOB)) <= 1024 THEN subject END, CASE WHEN typeof(preview) = 'text' AND length(CAST(preview AS BLOB)) <= 1024 THEN preview END, CASE WHEN typeof(received_at) = 'integer' THEN received_at END, CASE WHEN typeof(unread) = 'integer' THEN unread END, CASE WHEN content IS NULL THEN 0 WHEN typeof(content) = 'blob' AND length(content) <= ?2 THEN 1 ELSE -1 END, CASE WHEN typeof(content) = 'blob' AND length(content) <= ?2 THEN content END FROM messages WHERE message_id = ?1").map_err(store_error)?;
   671	                let mut rows = statement
   672	                    .query(params![id.as_str(), max_content_len])
   673	                    .map_err(store_error)?;
   674	                let Some(row) = rows.next().map_err(store_error)? else { return Ok(None); };
   675	                let envelope = envelope_from_row(row)?;
   676	                match row.get::<_, i64>(7).map_err(corrupted)? {
   677	                    0 => Ok(None),
   678	                    1 => {
   679	                        let content: Vec<u8> = row.get(8).map_err(corrupted)?;
   680	                        MessageContent::new(content)
   681	                            .map_err(|_error| MailboxStoreError::Corrupted)
   682	                            .map(|content| Some(Message::new(envelope, content)))
   683	                    }
   684	                    _ => Err(MailboxStoreError::Corrupted),
   685	                }
   686	            })
   687	        }
   688	    }
