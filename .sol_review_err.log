   224	impl<R, S> SyncCoordinator<R, S>
   225	where
   226	    R: RemoteMailbox,
   227	    S: MailboxStore,
   228	{
   229	    /// Creates a coordinator over inward remote and store ports.
   230	    #[must_use]
   231	    pub fn new(remote: R, store: S) -> Self {
   232	        Self {
   233	            remote,
   234	            store,
   235	            active_accounts: Mutex::new(HashSet::new()),
   236	        }
   237	    }
   238	
   239	    /// Lazily synchronizes one bounded recent snapshot for `account`.
   240	    ///
   241	    /// Dropping the returned future stops subsequent work and releases the
   242	    /// account's single-flight claim. This method performs no detached work.
   243	    pub fn sync_recent<'a>(
   244	        &'a self,
   245	        account: &'a AccountId,
   246	        policy: SyncPolicy,
   247	        fence: &'a IdentityHash,
   248	    ) -> BoxFuture<'a, Result<SyncReport, SyncFailure>> {
   249	        Box::pin(async move {
   250	            let flight = self.acquire(account)?;
   251	            let result = self.sync_with_flight(account, policy, fence).await;
   252	            drop(flight);
   253	            result
   254	        })
   255	    }
   256	
   257	    fn acquire(&self, account: &AccountId) -> Result<SyncFlight<'_, R, S>, SyncFailure> {
   258	        let mut active = self.active_accounts.lock().map_err(|_poison| SyncFailure {
   259	            source: SyncFailureSource::SingleFlight,
   260	            progress: SyncProgress::default(),
   261	        })?;
   262	        if !active.insert(account.clone()) {
   263	            return Err(SyncFailure {
   264	                source: SyncFailureSource::SingleFlight,
   265	                progress: SyncProgress::default(),
   266	            });
   267	        }
   268	        Ok(SyncFlight {
   269	            coordinator: self,
   270	            account: account.clone(),
   271	        })
   272	    }
   273	
   274	    async fn sync_with_flight(
   275	        &self,
   276	        account: &AccountId,
   277	        policy: SyncPolicy,
   278	        fence: &IdentityHash,
   279	    ) -> Result<SyncReport, SyncFailure> {
   280	        let mut progress = SyncProgress::default();
   281	        let capacity = usize::from(policy.keep_limit.get());
   282	        let page_capacity = usize::from(policy.page_size.get());
   283	        let mut envelopes = Vec::with_capacity(capacity.saturating_add(page_capacity));
   284	        let mut envelope_positions = HashMap::with_capacity(capacity.saturating_add(page_capacity));
   285	        let mut tokens = Vec::with_capacity(usize::from(policy.max_pages));
   286	        let mut next_token = None;
   287	
   288	        for _ in 0..policy.max_pages {
   289	            let page = self
   290	                .remote
   291	                .list_recent_envelopes(account, policy.page_size, next_token.as_ref())
   292	                .await
   293	                .map_err(|error| failure(SyncFailureSource::Remote(error), progress))?;
   294	            progress.pages += 1;
   295	            let (items, continuation) = page.into_parts();
   296	            if items.len() > usize::from(policy.page_size.get()) {
   297	                return Err(failure(
   298	                    SyncFailureSource::Protocol(SyncProtocolError::OversizedPage),
   299	                    progress,
   300	                ));
   301	            }
   302	            for envelope in items {
   303	                if let Some(position) = envelope_positions.get(envelope.message_id()) {
   304	                    if envelopes[*position] != envelope {
   305	                        return Err(failure(
   306	                            SyncFailureSource::Protocol(SyncProtocolError::ConflictingDuplicate),
   307	                            progress,
   308	                        ));
   309	                    }
   310	                    continue;
   311	                }
   312	                envelope_positions.insert(envelope.message_id().clone(), envelopes.len());
   313	                envelopes.push(envelope);
   314	                if envelopes.len() <= capacity {
   315	                    progress.envelopes += 1;
   316	                }
   317	            }
   318	            let reached_keep_limit = envelopes.len() >= capacity;
   319	            if envelopes.len() > capacity {
   320	                envelopes.truncate(capacity);
   321	            }
   322	            if let Some(token) = continuation.as_ref()
   323	                && tokens.iter().any(|seen| seen == token)
   324	            {
   325	                return Err(failure(
   326	                    SyncFailureSource::Protocol(SyncProtocolError::RepeatedContinuation),
   327	                    progress,
   328	                ));
   329	            }
   330	            if reached_keep_limit {
   331	                progress.snapshot_truncated = true;
   332	                break;
   333	            }
   334	            let Some(token) = continuation else {
   335	                break;
   336	            };
   337	            tokens.push(token.clone());
   338	            if progress.pages == policy.max_pages {
   339	                progress.snapshot_truncated = true;
   340	                break;
   341	            }
   342	            next_token = Some(token);
   343	        }
   344	
   345	        let survivors = self
   346	            .store
   347	            .reconcile_recent_envelopes(account, &envelopes, policy.keep_limit, fence)
   348	            .await
   349	            .map_err(|error| failure(store_failure_source(error), progress))?;
   350	        let body_limit = usize::from(policy.full_body_limit.get());
   351	        for id in survivors.into_iter().take(body_limit) {
   352	            progress.body_requests += 1;
   353	            match self.remote.fetch_message(account, &id).await {
   354	                Ok(message) => {
   355	                    if message.envelope().message_id() != &id {
   356	                        return Err(failure(
   357	                            SyncFailureSource::Protocol(
   358	                                SyncProtocolError::MismatchedFetchedMessage,
   359	                            ),
   360	                            progress,
   361	                        ));
   362	                    }
   363	                    if self
   364	                        .store
   365	                        .cache_message_if_present(account, &message, fence)
   366	                        .await
   367	                        .map_err(|error| failure(store_failure_source(error), progress))?
   368	                    {
   369	                        progress.bodies_cached += 1;
   370	                    } else {
   371	                        progress.bodies_skipped += 1;
   372	                    }
   373	                }
   374	                Err(RemoteMailboxError::NotFound) => progress.bodies_skipped += 1,
   375	                Err(error) => return Err(failure(SyncFailureSource::Remote(error), progress)),
   376	            }
   377	        }
   378	        Ok(SyncReport { progress })
   379	    }
   380	}
   381	
   382	fn failure(source: SyncFailureSource, progress: SyncProgress) -> SyncFailure {
   383	    SyncFailure { source, progress }
   384	}
   385	
   386	/// Maps a store error to a sync-failure source, surfacing the in-transaction
   387	/// identity fence as its own category rather than a generic store failure.
   388	fn store_failure_source(error: MailboxStoreError) -> SyncFailureSource {
   389	    match error {
   390	        MailboxStoreError::IdentityChanged => SyncFailureSource::IdentityFenced,
   391	        other => SyncFailureSource::Store(other),
   392	    }
   393	}
