  4665	        #[test]
   285	    ) -> BoxFuture<'a, Result<Vec<MessageEnvelope>, MailboxStoreError>>;
   286	    /// Lists one thread's envelopes in a deterministic total order: received
   287	    /// time ascending, then message identifier ascending, limited by the local
   288	    /// result limit.
   289	    ///
   290	    /// # Errors
   291	    ///
   292	    /// Returns an opaque store error when the account is not authorized, the
   293	    /// store cannot be read, or persisted values violate domain invariants.
   294	    fn thread_envelopes<'a>(
   295	        &'a self,
   296	        account: &'a AccountId,
   297	        thread_id: &'a ThreadId,
   298	        limit: StoreLimit,
   299	    ) -> BoxFuture<'a, Result<Vec<MessageEnvelope>, MailboxStoreError>>;
   300	}
   301	
   302	/// Persists mailbox data in a local store.
   303	///
   304	/// Store mutations must be atomic and all-or-nothing. After dropping a future,
   305	/// the outcome may be unknown, but partial durable state is forbidden; callers
   306	/// may reconcile by re-reading. Each concrete adapter must test its own
   307	/// cancellation and atomicity behavior. Reusable cross-crate test support is
   308	/// deferred.
   309	pub trait MailboxStore: MailboxReader {
   310	    /// Inserts or replaces mailbox envelopes for an account.
   311	    fn upsert_envelopes<'a>(
   312	        &'a self,
   313	        account: &'a AccountId,
   314	        envelopes: &'a [MessageEnvelope],
   315	    ) -> BoxFuture<'a, Result<(), MailboxStoreError>>;
   316	    /// Inserts or replaces one complete message for an account.
   317	    fn put_message<'a>(
   318	        &'a self,
   319	        account: &'a AccountId,
   320	        message: &'a Message,
   321	    ) -> BoxFuture<'a, Result<(), MailboxStoreError>>;
   322	    /// Atomically reconciles a recent envelope snapshot and returns survivors.
   323	    ///
   324	    /// The mutation upserts `envelopes` while preserving existing cached bodies,
   325	    /// then retains only the newest `keep_limit` rows ordered by received time
   326	    /// descending and message identifier ascending. Returned identifiers form a
   327	    /// duplicate-free subsequence of input encounter order and name only input
   328	    /// rows that survived that deterministic pruning.
   329	    /// Implementations reject an input longer than [`StoreLimit::MAX`].
   330	    ///
   331	    /// `fence` is the account-identity hash the sync cycle computed at its gate.
   332	    /// The write commits only if the store's recorded identity for `account` still
   333	    /// equals `fence` inside the same transaction; a changed or missing identity
   334	    /// aborts with [`MailboxStoreError::IdentityChanged`], so a stale cycle can
   335	    /// never persist envelopes under a different account.
   336	    fn reconcile_recent_envelopes<'a>(
   337	        &'a self,
   338	        account: &'a AccountId,
   339	        envelopes: &'a [MessageEnvelope],
   340	        keep_limit: StoreLimit,
   341	        fence: &'a IdentityHash,
   342	    ) -> BoxFuture<'a, Result<Vec<MessageId>, MailboxStoreError>>;
   343	    /// Caches a complete message only if its envelope row is still present.
   344	    ///
   345	    /// This is one atomic conditional mutation. It never inserts a missing row
   346	    /// and reports whether the existing row was updated. It is fenced by the
   347	    /// account-identity hash exactly as [`Self::reconcile_recent_envelopes`] is:
   348	    /// a stale body-fetch cannot land a cache write under a different account,
   349	    /// even on a colliding message identifier.
   350	    fn cache_message_if_present<'a>(
   351	        &'a self,
   352	        account: &'a AccountId,
   353	        message: &'a Message,
   354	        fence: &'a IdentityHash,
   355	    ) -> BoxFuture<'a, Result<bool, MailboxStoreError>>;
   356	    /// Retrieves an optional complete message.
   357	    fn message<'a>(
   358	        &'a self,
   359	        account: &'a AccountId,
   360	        message_id: &'a MessageId,
   361	    ) -> BoxFuture<'a, Result<Option<Message>, MailboxStoreError>>;
   362	}
