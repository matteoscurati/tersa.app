    73	/// Resolves the account-identity gate before any sync write.
    74	///
    75	/// Hashes the connected account's validated subject against the
    76	/// installation-derived salt, compares it with the recorded hash for the fixed
    77	/// account slot, and either records it (first connect), preserves the cached
    78	/// mailbox (same account), or clears the cached mailbox and records the new hash
    79	/// in one transaction (different account).
    80	///
    81	/// Fails closed: a hasher or store-read failure returns a [`GateError`] and the
    82	/// caller must not proceed to any sync write. A read failure is never mistaken
    83	/// for a first connect, so an unavailable identity can never re-baseline the
    84	/// store to whoever happens to be connected. The subject itself is in-hand and
    85	/// already validated (by the session at construction), so obtaining it is
    86	/// infallible.
    87	async fn run_identity_gate<P, H, St>(
    88	    account: &AccountId,
    89	    profile: &P,
    90	    hasher: &H,
    91	    store: &St,
    92	) -> Result<IdentityHash, GateError>
    93	where
    94	    P: AccountProfile,
    95	    H: AccountIdentityHasher,
    96	    St: AccountIdentityStore,
    97	{
    98	    let normalized = normalize_subject(profile.subject());
    99	    let fresh = hasher
   100	        .hash(account, &normalized)
   101	        .map_err(GateError::Hasher)?;
   102	    drop(normalized);
   103	    let stored = store
   104	        .load_identity(account)
   105	        .await
   106	        .map_err(GateError::Store)?;
   107	    let action = match decide(stored.as_ref(), &fresh) {
   108	        // The same account: preserve the cached mailbox, write nothing.
   109	        IdentityDecision::Match => return Ok(fresh),
   110	        IdentityDecision::FirstRecord => IdentityReconcile::RecordOnly,
   111	        IdentityDecision::ClearAndRecord => IdentityReconcile::ClearMailboxAndRecord,
   112	    };
   113	    store
   114	        .reconcile_identity(account, &fresh, action)
   115	        .await
   116	        .map_err(GateError::Store)?;
   117	    // The gate returns the hash it just committed as the fence for the sync: every
   118	    // subsequent mailbox write re-checks the recorded identity still equals it.
   119	    Ok(fresh)
   120	}
   121	
   122	/// Runs the account-identity gate, then the bounded recent sync — over one
   123	/// account session.
   124	///
   125	/// `session` exposes BOTH the profile-fetch surface (`AccountProfile`) and the
   126	/// mailbox-read surface (`RemoteMailbox`), so a single credential necessarily
   127	/// backs the identity check and the sync it guards. This makes the gate's core
   128	/// invariant — the account whose identity is checked is the account whose mail is
   129	/// written — a type-level guarantee, not a caller contract: a caller cannot check
   130	/// one Google user's identity and then sync a different user's mail, because there
   131	/// is only one session (hence one access token) to build both surfaces from. The
   132	/// concrete macOS session (3d-3) must therefore hold a single access token and
   133	/// derive both surfaces from it.
   134	///
   135	/// The gate borrows the session and completes first; only then is the session
   136	/// moved into a [`SyncCoordinator`] as the remote and the sync driven. Because
   137	/// the gate runs to a successful completion before the coordinator exists, a
   138	/// blocked gate means `sync_recent` — and therefore every mailbox write — never
   139	/// runs.
   140	///
   141	/// The identity hash is recorded (or the mailbox cleared and the hash recorded)
   142	/// inside the gate, committed BEFORE any message is synced. So a "messages present
   143	/// but identity absent" state — which the missing-row-is-first-connect branch
   144	/// would misread — is unreachable without tampering with the encrypted store
   145	/// itself, which already requires the database key.
   146	///
   147	/// # Concurrency
   148	///
   149	/// This function requires external per-account serialization across the WHOLE
   150	/// gate-to-write cycle and MUST NOT be called concurrently for the same account
   151	/// slot. The gate's load/decide/record and the sync it guards are distinct steps
   152	/// (each call builds its own [`SyncCoordinator`], whose single-flight set is
   153	/// per-call, not shared), so two overlapping cycles could interleave a stale
   154	/// record over a committed one and let two accounts' mail coexist. Enforcement is
   155	/// NOT provided here: it belongs to the 3d-3 Rust-owned sync worker (the sole
   156	/// production caller, holding one whole-cycle permit per slot) plus an
   157	/// in-transaction identity fence that re-checks the recorded hash inside every
   158	/// mailbox-write transaction. Callers without that discipline break the invariant.
   159	///
   160	/// # Errors
   161	///
   162	/// Returns [`GatedSyncError::Gate`] when the identity gate blocks the sync (no
   163	/// write occurred) and [`GatedSyncError::Sync`] when the bounded sync fails.
   164	pub async fn gated_sync<S, St, H>(
   165	    account: &AccountId,
   166	    session: S,
   167	    hasher: &H,
   168	    store: St,
   169	    policy: SyncPolicy,
   170	) -> Result<SyncReport, GatedSyncError>
   171	where
   172	    S: AccountProfile + RemoteMailbox,
   173	    St: MailboxStore + AccountIdentityStore,
   174	    H: AccountIdentityHasher,
   175	{
   176	    let fence = run_identity_gate(account, &session, hasher, &store)
   177	        .await
   178	        .map_err(GatedSyncError::Gate)?;
   179	    let coordinator = SyncCoordinator::new(session, store);
   180	    coordinator
   181	        .sync_recent(account, policy, &fence)
   182	        .await
   183	        .map_err(GatedSyncError::Sync)
   184	}
   185	
   186	/// A connected account's short-lived access token and validated OIDC subject.
   187	///
   188	/// Produced by [`connect_account`] and [`refresh_account`] from a SINGLE token
   189	/// response, so the access token and the identity-gate `subject` always share an
   190	/// origin (the same principal). 3d-3 builds the sync session from both, feeding
   191	/// the subject to the gate and the access token to the mailbox surface.
   192	#[cfg(target_os = "macos")]
   193	#[derive(Debug)]
   194	pub struct ConnectedAccount {
   195	    access_token: AccessToken,
   196	    subject: AccountSubject,
   197	    identity_expiry: IdentityExpiry,
   198	}
   199	
   200	#[cfg(target_os = "macos")]
   201	impl ConnectedAccount {
   202	    /// Returns the short-lived access token with its monotonic expiry.
   203	    #[must_use]
   204	    pub fn access_token(&self) -> &AccessToken {
   205	        &self.access_token
   220	            .finish_non_exhaustive()
   221	    }
   222	}
