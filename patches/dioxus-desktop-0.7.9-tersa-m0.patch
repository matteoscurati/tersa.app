+fn open_external_if_allowed<E>(
+    href: &str,
+    navigation_handler: Option<&NavigationHandler>,
+    open: impl FnOnce(&str) -> Result<(), E>,
+) -> Result<(), E> {
+    if navigation_handler.is_some_and(|handler| !handler(href)) {
+        return Ok(());
+    }
+    open(href)
+}
