+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub(crate) enum NavigationDecision {
+    Allow,
+    Deny,
+    OpenExternal,
+}
+
+pub(crate) fn navigation_decision(
+    url: &str,
+    already_loaded: bool,
+    navigation_handler: Option<&NavigationHandler>,
+) -> NavigationDecision {
+    if is_dioxus_internal_url(url) {
+        return if already_loaded {
+            NavigationDecision::Deny
+        } else {
+            NavigationDecision::Allow
+        };
+    }
+
+    if let Some(handler) = navigation_handler {
+        return if handler(url) {
+            NavigationDecision::Allow
+        } else {
+            NavigationDecision::Deny
+        };
+    }
+
+    if is_external_browser_url(url) {
+        NavigationDecision::OpenExternal
+    } else {
+        NavigationDecision::Allow
+    }
+}
+
+fn is_dioxus_internal_url(url: &str) -> bool {
+    url.starts_with("dioxus://")
+        || url.starts_with("http://dioxus.")
+        || url.starts_with("https://dioxus.")
+}
+
+fn is_external_browser_url(url: &str) -> bool {
+    url.starts_with("http://") || url.starts_with("https://") || url.starts_with("mailto:")
+}
+
+#[cfg(test)]
+mod navigation_tests {
+    use super::{navigation_decision, NavigationDecision};
+    use crate::config::NavigationHandler;
+    use std::rc::Rc;
+
+    #[test]
+    fn initial_internal_navigation_is_allowed_and_reload_is_denied() {
+        assert_eq!(
+            navigation_decision("dioxus://index.html/", false, None),
+            NavigationDecision::Allow
+        );
+        assert_eq!(
+            navigation_decision("dioxus://index.html/", true, None),
+            NavigationDecision::Deny
+        );
+    }
+
+    #[test]
+    fn deny_handler_precedes_external_browser_fallback() {
+        let deny: NavigationHandler = Rc::new(|_| false);
+        for url in [
+            "http://example.test",
+            "https://example.test",
+            "mailto:test@example.test",
+        ] {
+            assert_eq!(
+                navigation_decision(url, false, Some(&deny)),
+                NavigationDecision::Deny
+            );
+        }
+    }
+
+    #[test]
+    fn no_handler_preserves_external_browser_fallback_and_unknown_schemes() {
+        for url in [
+            "http://example.test",
+            "https://example.test",
+            "mailto:test@example.test",
+        ] {
+            assert_eq!(
+                navigation_decision(url, false, None),
+                NavigationDecision::OpenExternal
+            );
+        }
+        assert_eq!(
+            navigation_decision("unknown:route", false, None),
+            NavigationDecision::Allow
+        );
+    }
+}
