+    #[test]
+    fn deny_policy_prevents_ipc_browser_open() {
+        let deny: NavigationHandler = Rc::new(|_| false);
+        let opened = Cell::new(false);
+
+        let result = open_external_if_allowed("https://example.test", Some(&deny), |_| {
+            opened.set(true);
+            Ok::<(), ()>(())
+        });
+
+        assert_eq!(result, Ok(()));
+        assert!(!opened.get());
+    }
+}
