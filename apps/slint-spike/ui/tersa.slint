import { Button, LineEdit, ListView, TextEdit } from "std-widgets.slint";

export struct InboxRow {
    sender: string,
    subject: string,
    preview: string,
    time: string,
    unread: bool,
}

export component TersaSlintSpike inherits Window {
    title: "Tersa Slint feasibility spike";
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 360px;
    min-height: 640px;
    background: #f4f3ee;

    in property <[InboxRow]> rows;
    in property <int> protocol-version;
    private property <bool> compact: root.width < 700px;

    if !root.compact: Rectangle {
        background: #f4f3ee;

        HorizontalLayout {
            padding-top: root.safe-area-insets.top;
            padding-right: root.safe-area-insets.right;
            padding-bottom: root.safe-area-insets.bottom;
            padding-left: root.safe-area-insets.left;
            spacing: 0px;

            Rectangle {
                width: root.compact ? 0px : 58px;
                background: #143e75;
                vertical-stretch: 1;
                VerticalLayout {
                    padding-top: 24px;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 20px;
                    Text { text: "T"; color: #f4f3ee; font-size: 24px; font-weight: 700; horizontal-alignment: center; accessible-role: none; }
                    Text { text: "IN"; color: #d6e4fb; font-size: 11px; horizontal-alignment: center; accessible-role: none; }
                    Text { text: "DQ"; color: #d6e4fb; font-size: 11px; horizontal-alignment: center; accessible-role: none; }
                    Text { text: "AR"; color: #d6e4fb; font-size: 11px; horizontal-alignment: center; accessible-role: none; }
                }
            }

            Rectangle {
                width: root.compact ? 0px : 330px;
                background: #e9e8e2;
                border-color: #c9cbd0;
                border-width: 1px;
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    Text { text: "INBOX / 10,000 ROWS"; color: #14213a; font-size: 12px; font-weight: 700; }
                    LineEdit {
                        height: 36px;
                        text: "";
                        placeholder-text: "Search diagnostic inbox";
                        accessible-label: "Search diagnostic inbox";
                    }
                    ListView {
                        accessible-role: list;
                        accessible-label: "Diagnostic inbox with 10,000 rows";
                        vertical-stretch: 1;
                        for row[i] in root.rows: Rectangle {
                            accessible-role: list-item;
                            accessible-label: row.sender + ", " + row.subject + ", " + row.time;
                            height: 64px;
                            background: i == 0 ? #dbe8fa : #e9e8e2;
                            border-color: #d4d5d1;
                            border-width: 1px;
                            VerticalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                padding-top: 7px;
                                spacing: 2px;
                                HorizontalLayout {
                                    Text { text: row.sender; color: #14213a; font-weight: row.unread ? 700 : 400; font-size: 13px; horizontal-stretch: 1; }
                                    Text { text: row.time; color: #526071; font-size: 11px; }
                                }
                                Text { text: row.subject; color: #14213a; font-weight: row.unread ? 700 : 400; font-size: 13px; }
                                Text { text: row.preview; color: #526071; font-size: 11px; overflow: elide; }
                            }
                        }
                    }
                }
            }

            Rectangle {
                background: #ffffff;
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 28px;
                    spacing: 16px;
                    Text { text: "DIAGNOSTIC THREAD 00001"; color: #143e75; font-size: 12px; font-weight: 700; }
                    Text { text: "A deliberately synthetic message surface"; color: #14213a; font-size: 28px; font-weight: 700; wrap: word-wrap; }
                    Text { text: "Stable marker: TERSA-SLINT-M0-THREAD. This mock validates only layout, input, virtual scrolling, and native packaging."; color: #526071; font-size: 15px; wrap: word-wrap; }
                    Rectangle { height: 1px; background: #d4d5d1; }
                    Text { text: "No account is connected. No network, OAuth, storage, HTML, or WebView is present."; color: #14213a; font-size: 14px; wrap: word-wrap; vertical-stretch: 1; }
                    TextEdit {
                        height: 170px;
                        text: "";
                        placeholder-text: "Compose diagnostic note";
                        accessible-label: "Diagnostic message composer";
                    }
                    HorizontalLayout {
                        Text { text: "PROTOCOL " + root.protocol-version; color: #526071; font-size: 11px; horizontal-stretch: 1; }
                        Button { text: "Diagnostic action"; }
                    }
                }
            }
        }
    }

    if root.compact: Rectangle {
        background: #f4f3ee;

        VerticalLayout {
            padding-top: max(16px, root.safe-area-insets.top + 12px);
            padding-right: max(16px, root.safe-area-insets.right + 12px);
            padding-bottom: max(16px, root.safe-area-insets.bottom + 10px);
            padding-left: max(16px, root.safe-area-insets.left + 12px);
            spacing: 10px;

            HorizontalLayout {
                Text { text: "TERSA"; color: #143e75; font-size: 18px; font-weight: 700; horizontal-stretch: 1; }
                Text { text: "M0 / 10,000"; color: #526071; font-size: 11px; }
            }

            LineEdit {
                height: 38px;
                text: "";
                placeholder-text: "Search diagnostic inbox";
                accessible-label: "Search diagnostic inbox";
            }

            ListView {
                accessible-role: list;
                accessible-label: "Diagnostic inbox with 10,000 rows";
                vertical-stretch: 1;
                for row[i] in root.rows: Rectangle {
                    accessible-role: list-item;
                    accessible-label: row.sender + ", " + row.subject + ", " + row.time;
                    height: 58px;
                    background: i == 0 ? #dbe8fa : #f4f3ee;
                    border-color: #d4d5d1;
                    border-width: 1px;
                    VerticalLayout {
                        padding-left: 9px;
                        padding-right: 9px;
                        padding-top: 6px;
                        spacing: 2px;
                        HorizontalLayout {
                            Text { text: row.sender; color: #14213a; font-weight: row.unread ? 700 : 400; font-size: 13px; horizontal-stretch: 1; }
                            Text { text: row.time; color: #526071; font-size: 11px; }
                        }
                        Text { text: row.subject; color: #14213a; font-weight: row.unread ? 700 : 400; font-size: 13px; overflow: elide; }
                        Text { text: row.preview; color: #526071; font-size: 11px; overflow: elide; }
                    }
                }
            }

            Text { text: "TERSA-SLINT-M0-THREAD / PROTOCOL " + root.protocol-version; color: #143e75; font-size: 10px; font-weight: 700; }
            TextEdit {
                height: 108px;
                text: "";
                placeholder-text: "Compose diagnostic note";
                accessible-label: "Diagnostic message composer";
            }
        }
    }
}
